# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Server directory (Paper install). Relative paths are from repo root.
MC_SERVER_DIR=./server

# Process control: auto = real Java if server.jar exists; stub = fake server; real = always Java
MC_PROCESS_MODE=auto
MC_JAVA_BIN=java
# Windows example if java is not on PATH:
# MC_JAVA_BIN=C:\Program Files\Java\jdk-25.0.3\bin\java.exe
MC_JAVA_ARGS=-Xms2G -Xmx2G
MC_SERVER_JAR=server.jar
MC_STOP_TIMEOUT_SECONDS=30
MC_RESTART_PAUSE_SECONDS=2

# RCON graceful stop for servers started outside this app.
# Also set enable-rcon=true and matching rcon.password in server.properties.
MC_RCON_ENABLED=false
MC_RCON_HOST=127.0.0.1
MC_RCON_PORT=25575
MC_RCON_PASSWORD=change-me
MC_RCON_TIMEOUT_SECONDS=3

# Agent / verification tuning
SMOKE_TEST_SECONDS=5
MAX_AGENT_STEPS=12

# Plugin catalog (Hangar, Modrinth, SpigotMC)
MC_MINECRAFT_VERSION=1.21
MC_PLUGIN_CACHE_DIR=./plugin-cache
MC_PLUGIN_BLOCKLIST=
PLUGIN_SEARCH_LIMIT=10
